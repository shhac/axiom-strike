	banner_bg = gui.new_box_node(vmath.vector3(640, 700, 0), vmath.vector3(550, 38, 0))
	gui.set_color(banner_bg, C.banner_atk)

	banner_text = gui.new_text_node(vmath.vector3(640, 700, 0), "")
	gui.set_font(banner_text, "system_font")
	gui.set_color(banner_text, C.text_atk)

	-- Target display
	target_bg = gui.new_box_node(vmath.vector3(480, 380, 0), vmath.vector3(110, 60, 0))
	gui.set_color(target_bg, vmath.vector4(0.12, 0.2, 0.42, 0.9))

	target_label = gui.new_text_node(vmath.vector3(480, 398, 0), "TARGET")
	gui.set_font(target_label, "system_font")
	gui.set_scale(target_label, vmath.vector3(0.55, 0.55, 1))
	gui.set_color(target_label, vmath.vector4(0.55, 0.7, 1, 1))

	target_text = gui.new_text_node(vmath.vector3(480, 372, 0), "")
	gui.set_font(target_text, "system_font")
	gui.set_scale(target_text, vmath.vector3(2.0, 2.0, 1))
	gui.set_color(target_text, C.white)

	wave_text = gui.new_text_node(vmath.vector3(1220, 700, 0), "")
	gui.set_font(wave_text, "system_font")
	gui.set_scale(wave_text, vmath.vector3(0.7, 0.7, 1))
	gui.set_color(wave_text, vmath.vector4(0.5, 0.5, 0.65, 1))

	-- Enemy HP bar (top-right, symmetric with hero HP)
	enemy_hp_bg = gui.new_box_node(vmath.vector3(1040, 700, 0), vmath.vector3(200, 16, 0))
	gui.set_color(enemy_hp_bg, vmath.vector4(0.15, 0.12, 0.25, 1))
	gui.set_pivot(enemy_hp_bg, gui.PIVOT_E)

	enemy_hp_fill = gui.new_box_node(vmath.vector3(1040, 700, 0), vmath.vector3(200, 14, 0))
	gui.set_color(enemy_hp_fill, vmath.vector4(1, 0.45, 0.25, 1))
	gui.set_pivot(enemy_hp_fill, gui.PIVOT_E)

	enemy_hp_text = gui.new_text_node(vmath.vector3(940, 700, 0), "")
	gui.set_font(enemy_hp_text, "system_font")
	gui.set_scale(enemy_hp_text, vmath.vector3(0.9, 0.9, 1))
	gui.set_color(enemy_hp_text, C.white)
end

local function update_enemy_hud(hp, max_hp)
	if not enemy_hp_fill then return end
	local ratio = hp / max_hp
	gui.set_size(enemy_hp_fill, vmath.vector3(200 * ratio, 14, 0))
	gui.set_text(enemy_hp_text, tostring(hp))
	local c = ratio > 0.5 and vmath.vector4(1, 0.5, 0.25, 1) or vmath.vector4(1, 0.25, 0.2, 1)
	gui.set_color(enemy_hp_fill, c)
end

local function set_attack_mode(weakness)
	gui.set_color(banner_bg, C.banner_atk)
	gui.set_text(banner_text, "YOUR TURN  --  ATTACK!")
	gui.set_color(banner_text, C.text_atk)
	gui.set_color(target_bg, vmath.vector4(0.12, 0.22, 0.48, 0.9))
	gui.set_text(target_label, "WEAKNESS")
	gui.set_color(target_label, vmath.vector4(0.5, 0.7, 1, 1))
	gui.set_text(target_text, tostring(weakness))
	gui.set_color(target_text, C.white)
	gui.set_text(gui.get_node("btn_strike_text"), "STRIKE!")
	gui.set_color(gui.get_node("btn_strike"), C.btn_green)
end

local function set_defend_mode(attack_number)
	gui.set_color(banner_bg, C.banner_def)
	gui.set_text(banner_text, "DEFEND!  Build this number:")
	gui.set_color(banner_text, C.text_def)
	gui.set_color(target_bg, vmath.vector4(0.48, 0.1, 0.1, 0.9))
	gui.set_text(target_label, "BLOCK")
	gui.set_color(target_label, vmath.vector4(1, 0.6, 0.5, 1))
	gui.set_text(target_text, tostring(attack_number))
	gui.set_color(target_text, vmath.vector4(1, 0.92, 0.82, 1))
	gui.set_text(gui.get_node("btn_strike_text"), "BLOCK!")
	gui.set_color(gui.get_node("btn_strike"), C.btn_red)
end

-- ============================================================
-- Tiles
-- ============================================================

local function create_tile_nodes()
	for _, n in ipairs(number_tile_nodes) do gui.delete_node(n.box); gui.delete_node(n.text) end
	for _, n in ipairs(operator_tile_nodes) do gui.delete_node(n.box); gui.delete_node(n.text) end
	number_tile_nodes = {}
	operator_tile_nodes = {}

	for i = 1, #number_tile_values do
		local x = NUM_START_X + (i - 1) * (TILE_W + TILE_GAP)
		local box = gui.new_box_node(vmath.vector3(x, NUM_Y, 0), vmath.vector3(TILE_W, TILE_H, 0))
		gui.set_color(box, C.tile_num)
		local txt = gui.new_text_node(vmath.vector3(x, NUM_Y, 0), tostring(number_tile_values[i]))
		gui.set_font(txt, "system_font")
		gui.set_scale(txt, vmath.vector3(1.3, 1.3, 1))
		gui.set_color(txt, C.tile_text)
		number_tile_nodes[i] = {box = box, text = txt}
		-- Pop-in staggered + wiggle
		gui.set_scale(box, vmath.vector3(0, 0, 1))
		gui.set_scale(txt, vmath.vector3(0, 0, 1))
		gui.animate(box, gui.PROP_SCALE, vmath.vector3(1, 1, 1), gui.EASING_OUTBACK, 0.3, i * 0.05)
		gui.animate(txt, gui.PROP_SCALE, vmath.vector3(1.3, 1.3, 1), gui.EASING_OUTBACK, 0.3, i * 0.05)
		wiggle(box, 2, 1.5 + math.random() * 0.5)
	end

	for i = 1, #operator_tile_values do
		local x = OP_START_X + (i - 1) * (TILE_W + TILE_GAP)
		local box = gui.new_box_node(vmath.vector3(x, OP_Y, 0), vmath.vector3(TILE_W, TILE_H, 0))
		gui.set_color(box, C.tile_op)
		local txt = gui.new_text_node(vmath.vector3(x, OP_Y, 0), operator_tile_values[i])
		gui.set_font(txt, "system_font")
		gui.set_scale(txt, vmath.vector3(1.4, 1.4, 1))
		gui.set_color(txt, C.tile_text)
		operator_tile_nodes[i] = {box = box, text = txt}
		-- Pop-in staggered + wiggle
		gui.set_scale(box, vmath.vector3(0, 0, 1))
		gui.set_scale(txt, vmath.vector3(0, 0, 1))
		local delay = (#number_tile_values + i) * 0.05
		gui.animate(box, gui.PROP_SCALE, vmath.vector3(1, 1, 1), gui.EASING_OUTBACK, 0.3, delay)
		gui.animate(txt, gui.PROP_SCALE, vmath.vector3(1.4, 1.4, 1), gui.EASING_OUTBACK, 0.3, delay)
		wiggle(box, 2.5, 1.3 + math.random() * 0.5)
	end
end

local function update_equation_display()
	gui.set_text(gui.get_node("equation_text"), equation.to_string(equation_tokens))
	local result, err = equation.evaluate(equation_tokens)
	if result and not err then
		gui.set_text(gui.get_node("equation_result"), "= " .. tostring(math.floor(result)))
	elseif #equation_tokens > 0 then
		gui.set_text(gui.get_node("equation_result"), "= ?")
	else
		gui.set_text(gui.get_node("equation_result"), "")
	end
end

local function dim_tile(nd) gui.set_color(nd.box, C.tile_used); gui.set_color(nd.text, C.tile_used_t) end
local function restore_tile(nd, is_num) gui.set_color(nd.box, is_num and C.tile_num or C.tile_op); gui.set_color(nd.text, C.tile_text) end

local function clear_equation()
	for key, _ in pairs(tile_used) do
		local prefix, idx = key:match("(%a+)_(%d+)"); idx = tonumber(idx)
		if prefix == "num" and number_tile_nodes[idx] then restore_tile(number_tile_nodes[idx], true)
		elseif prefix == "op" and operator_tile_nodes[idx] then restore_tile(operator_tile_nodes[idx], false) end
	end
	tile_used = {}; equation_tokens = {}; expecting_number = true
	update_equation_display(); gui.set_text(gui.get_node("closeness_label"), "")
end

local function undo_last()
	if #equation_tokens == 0 then return end
	local tok = table.remove(equation_tokens)
	if type(tok) == "number" then
		for i = #number_tile_nodes, 1, -1 do
			if tile_used["num_" .. i] and number_tile_values[i] == tok then tile_used["num_" .. i] = nil; restore_tile(number_tile_nodes[i], true); break end
		end
		expecting_number = true
	else
		for i = #operator_tile_nodes, 1, -1 do
			if tile_used["op_" .. i] and operator_tile_values[i] == tok then tile_used["op_" .. i] = nil; restore_tile(operator_tile_nodes[i], false); break end
		end
		expecting_number = false
	end
	update_equation_display(); gui.set_text(gui.get_node("closeness_label"), "")
end

-- ============================================================
-- Enemies (with faces and idle animation)
-- ============================================================

local function destroy_enemy_nodes()
	for _, en in ipairs(enemy_nodes) do
		for _, node in pairs(en) do if type(node) == "userdata" then gui.delete_node(node) end end
	end
	enemy_nodes = {}
end

local function create_enemy_nodes(enemies, target_index)
	destroy_enemy_nodes()

	-- Update enemy HP in top-right HUD (show targeted enemy's HP)
	if enemies[target_index] then
		update_enemy_hud(enemies[target_index].hp, enemies[target_index].max_hp)
	end

	for i, e in ipairs(enemies) do
		local x = ENEMY_START_X + (i - 1) * ENEMY_GAP
		local w = e.is_boss and 95 or 75
		local h = e.is_boss and 105 or 85
		local alive = e.alive
		local is_target = (i == target_index and alive)

		local body = gui.new_box_node(vmath.vector3(x, ENEMY_Y, 0), vmath.vector3(w, h, 0))
		gui.set_color(body, alive and C.enemy_body or C.enemy_dead)

		local belly = gui.new_box_node(vmath.vector3(x, ENEMY_Y - 10, 0), vmath.vector3(w - 14, h * 0.4, 0))
		gui.set_color(belly, alive and C.enemy_dark or C.enemy_dead)

		local ew, eh = e.is_boss and 15 or 12, e.is_boss and 17 or 13
		local el = gui.new_box_node(vmath.vector3(x - w * 0.2, ENEMY_Y + h * 0.15, 0), vmath.vector3(ew, eh, 0))
		gui.set_color(el, alive and C.enemy_eye or C.enemy_dead)
		local pl = gui.new_box_node(vmath.vector3(x - w * 0.2 + 1, ENEMY_Y + h * 0.12, 0), vmath.vector3(ew * 0.55, eh * 0.6, 0))
		gui.set_color(pl, alive and C.enemy_pupil or C.enemy_dead)

		local er = gui.new_box_node(vmath.vector3(x + w * 0.2, ENEMY_Y + h * 0.15, 0), vmath.vector3(ew, eh, 0))
		gui.set_color(er, alive and C.enemy_eye or C.enemy_dead)
		local pr = gui.new_box_node(vmath.vector3(x + w * 0.2 + 1, ENEMY_Y + h * 0.12, 0), vmath.vector3(ew * 0.55, eh * 0.6, 0))
		gui.set_color(pr, alive and C.enemy_pupil or C.enemy_dead)

		local mw = e.is_boss and 30 or 20
		local mouth = gui.new_box_node(vmath.vector3(x, ENEMY_Y - h * 0.1, 0), vmath.vector3(mw, 5, 0))
		gui.set_color(mouth, alive and C.enemy_mouth or C.enemy_dead)

		local fang_l, fang_r
		if e.is_boss and alive then
			fang_l = gui.new_box_node(vmath.vector3(x - 9, ENEMY_Y - h * 0.18, 0), vmath.vector3(5, 9, 0))
			gui.set_color(fang_l, C.white)
			fang_r = gui.new_box_node(vmath.vector3(x + 9, ENEMY_Y - h * 0.18, 0), vmath.vector3(5, 9, 0))
			gui.set_color(fang_r, C.white)
		end

		-- Weakness badge on enemy body
		local badge = gui.new_box_node(vmath.vector3(x, ENEMY_Y + h/2 + 16, 0), vmath.vector3(38, 22, 0))
		gui.set_color(badge, is_target and C.badge_gold or (alive and C.badge_red or C.enemy_dead))
		local wtext = gui.new_text_node(vmath.vector3(x, ENEMY_Y + h/2 + 16, 0), tostring(e.weakness))
		gui.set_font(wtext, "system_font")
		gui.set_scale(wtext, vmath.vector3(0.85, 0.85, 1))
		gui.set_color(wtext, alive and C.white or C.tile_used_t)

		-- Target arrow
		local arrow
		if is_target then
			arrow = gui.new_text_node(vmath.vector3(x, ENEMY_Y + h/2 + 36, 0), "v")
			gui.set_font(arrow, "system_font")
			gui.set_scale(arrow, vmath.vector3(1.1, 1.1, 1))
			gui.set_color(arrow, C.gold)
			bob(arrow, ENEMY_Y + h/2 + 36, 5, 0.6)
		end

		-- Slide-in + idle bob (each enemy slightly different timing)
		if alive then
			local all_parts = {body, belly, el, pl, er, pr, mouth, badge, wtext}
			if fang_l then all_parts[#all_parts+1] = fang_l; all_parts[#all_parts+1] = fang_r end
			for _, n in ipairs(all_parts) do
				-- Slide in from right
				local target_x = gui.get_position(n).x
				slide_in(n, target_x + 300, target_x, i * 0.12)
				-- Start bobbing after slide-in
				timer.delay(0.5 + i * 0.12, false, function()
					if gui.get_node then  -- guard against deleted nodes
						bob(n, gui.get_position(n).y, 3, 1.5 + i * 0.3)
					end
				end)
			end
		end

		enemy_nodes[i] = {
			body = body, belly = belly, el = el, pl = pl, er = er, pr = pr, mouth = mouth,
			fang_l = fang_l, fang_r = fang_r, badge = badge, wtext = wtext, arrow = arrow,
			alive = alive,
		}
	end
end

-- ============================================================
-- Between-waves overlay
-- ============================================================

local bw = {}

local function show_between_waves_ui(data)
	between_waves = true

	bw.overlay = gui.new_box_node(vmath.vector3(640, 400, 0), vmath.vector3(460, 280, 0))
	gui.set_color(bw.overlay, vmath.vector4(0.06, 0.05, 0.12, 0.95))

	bw.title = gui.new_text_node(vmath.vector3(640, 500, 0), "Wave " .. data.wave .. " incoming!")
	gui.set_font(bw.title, "system_font")
	gui.set_scale(bw.title, vmath.vector3(1.15, 1.15, 1))
	gui.set_color(bw.title, C.gold)

	bw.hp = gui.new_text_node(vmath.vector3(640, 450, 0), "HP: " .. data.hero_hp)
	gui.set_font(bw.hp, "system_font")
	gui.set_color(bw.hp, C.hp_green)

	bw.btn = gui.new_box_node(vmath.vector3(640, 380, 0), vmath.vector3(200, 50, 0))
	gui.set_color(bw.btn, C.btn_green)
	bw.btn_t = gui.new_text_node(vmath.vector3(640, 380, 0), "FIGHT!")
	gui.set_font(bw.btn_t, "system_font")
	gui.set_scale(bw.btn_t, vmath.vector3(1.1, 1.1, 1))
	gui.set_color(bw.btn_t, C.white)

	if data.recovery_available then
		bw.rest = gui.new_box_node(vmath.vector3(640, 320, 0), vmath.vector3(200, 50, 0))
		gui.set_color(bw.rest, vmath.vector4(0.12, 0.35, 0.2, 1))
		bw.rest_t = gui.new_text_node(vmath.vector3(640, 320, 0), "REST & READ")
		gui.set_font(bw.rest_t, "system_font")
		gui.set_color(bw.rest_t, vmath.vector4(0.35, 0.95, 0.55, 1))
	end
end

local function hide_between_waves_ui()
	between_waves = false
	for _, node in pairs(bw) do if type(node) == "userdata" then gui.delete_node(node) end end
	bw = {}
end

-- ============================================================
-- Lifecycle
-- ============================================================

function init(self)
	msg.post(".", "acquire_input_focus")
	input_enabled = false; battle_over = false; between_waves = false
	equation_tokens = {}; expecting_number = true; tile_used = {}
	create_scene()
	create_hud()

	-- Star twinkling on static star nodes
	for i = 1, 5 do
		local ok, star = pcall(gui.get_node, "star" .. i)
		if ok and star then
			gui.animate(star, "color.w", 0.1, gui.EASING_INOUTSINE,
				1.5 + math.random() * 2.0, math.random() * 1.5, nil, gui.PLAYBACK_LOOP_PINGPONG)
		end
	end
end

function on_message(self, message_id, message, sender)
	if message_id == hash("deal_tiles") then
		number_tile_values = message.numbers or {}
		operator_tile_values = message.operators or {}
		tile_used = {}; equation_tokens = {}; expecting_number = true
		create_tile_nodes(); update_equation_display()
		gui.set_text(gui.get_node("closeness_label"), "")
		input_enabled = true

	elseif message_id == hash("set_phase") then
		if message.mode == "attack" then set_attack_mode(message.weakness or 0)
		elseif message.mode == "defend" then set_defend_mode(message.attack_number or 0) end
		if message.wave_text and wave_text then gui.set_text(wave_text, message.wave_text) end

	elseif message_id == hash("update_hero_hp") then
		local ratio = message.hp / message.max_hp
		gui.set_size(gui.get_node("hero_hp_fill"), vmath.vector3(200 * ratio, 14, 0))
		gui.set_text(gui.get_node("hero_hp_text"), tostring(message.hp))
		pop_text(gui.get_node("hero_hp_text"))
		local c = ratio > 0.5 and C.hp_green or (ratio > 0.25 and C.hp_yellow or C.hp_red)
		gui.set_color(gui.get_node("hero_hp_fill"), c)

	elseif message_id == hash("sync_enemies") then
		create_enemy_nodes(message.enemies, message.target)

	elseif message_id == hash("highlight_attacker") then
		local idx = message.index
		if enemy_nodes[idx] then
			-- Flash red and shake to telegraph attack
			gui.set_color(enemy_nodes[idx].body, vmath.vector4(1, 0.3, 0.2, 1))
			shake(enemy_nodes[idx].body)
		end

	elseif message_id == hash("enemy_hit") then
		-- Flash white and shake enemy on damage
		local idx = message.index
		if enemy_nodes[idx] then
			flash_white(enemy_nodes[idx].body, C.enemy_body)
			shake(enemy_nodes[idx].body)
			pop(enemy_nodes[idx].body, 1.15, 0.2)
		end

	elseif message_id == hash("hero_hit") then
		-- Flash red and shake hero on damage
		for _, n in ipairs(scene_nodes) do
			shake(n)
		end

	elseif message_id == hash("show_damage") then
		local popup = gui.get_node("damage_popup")
		gui.set_text(popup, message.text or "")
		gui.set_position(popup, vmath.vector3(message.x or 640, message.y or 450, 0))
		gui.cancel_animation(popup, "position.y")
		gui.cancel_animation(popup, "color.w")
		gui.set_alpha(popup, 1.0)
		gui.set_scale(popup, vmath.vector3(1.6, 1.6, 1))
		gui.animate(popup, "position.y", (message.y or 450) + 70, gui.EASING_OUTQUAD, 0.9)
		gui.animate(popup, "color.w", 0, gui.EASING_OUTQUAD, 0.9, 0.3)

	elseif message_id == hash("disable_input") then input_enabled = false
	elseif message_id == hash("enable_input") then input_enabled = true

	elseif message_id == hash("show_result") then
		battle_over = true; input_enabled = false
		gui.set_alpha(gui.get_node("result_overlay"), 1.0)
		gui.set_alpha(gui.get_node("result_title"), 1.0)
		gui.set_text(gui.get_node("result_title"), message.title or "VICTORY!")
		gui.set_alpha(gui.get_node("btn_continue"), 1.0)
		gui.set_alpha(gui.get_node("btn_continue_text"), 1.0)

	elseif message_id == hash("show_between_waves") then
		input_enabled = false; show_between_waves_ui(message)
	end
end

function on_input(self, action_id, action)
	if action_id ~= hash("touch") or not action.pressed then return false end

	if between_waves then
		if bw.btn and gui.pick_node(bw.btn, action.x, action.y) then hide_between_waves_ui(); msg.post(SCRIPT_URL, "next_wave_pressed"); return true end
		if bw.rest and gui.pick_node(bw.rest, action.x, action.y) then hide_between_waves_ui(); msg.post(SCRIPT_URL, "recovery_pressed"); return true end
		return true
	end

	if battle_over then
		if gui.pick_node(gui.get_node("btn_continue"), action.x, action.y) then msg.post(SCRIPT_URL, "continue_pressed") end
		return true
	end

	if not input_enabled then return false end

	for i, en in ipairs(enemy_nodes) do
		if en.alive and gui.pick_node(en.body, action.x, action.y) then msg.post(SCRIPT_URL, "select_target", {index = i}); return true end
	end

	if gui.pick_node(gui.get_node("btn_strike"), action.x, action.y) then
		local result, err = equation.evaluate(equation_tokens)
		if result and not err then
			pop(gui.get_node("btn_strike"), 1.15, 0.2)
			input_enabled = false
			msg.post(SCRIPT_URL, "equation_submitted", {result = math.floor(result), tokens = equation_tokens})
		end
		return true
	end
	if gui.pick_node(gui.get_node("btn_undo"), action.x, action.y) then pop(gui.get_node("btn_undo")); undo_last(); return true end
	if gui.pick_node(gui.get_node("btn_clear"), action.x, action.y) then pop(gui.get_node("btn_clear")); clear_equation(); return true end

	if expecting_number then
		for i, nd in ipairs(number_tile_nodes) do
			if not tile_used["num_" .. i] and gui.pick_node(nd.box, action.x, action.y) then
				tile_used["num_" .. i] = true; pop(nd.box, 1.2, 0.15); dim_tile(nd); equation_tokens[#equation_tokens + 1] = number_tile_values[i]; expecting_number = false; update_equation_display(); return true
			end
		end
	else
		for i, nd in ipairs(operator_tile_nodes) do
			if not tile_used["op_" .. i] and gui.pick_node(nd.box, action.x, action.y) then
				tile_used["op_" .. i] = true; pop(nd.box, 1.2, 0.15); dim_tile(nd); equation_tokens[#equation_tokens + 1] = operator_tile_values[i]; expecting_number = true; update_equation_display(); return true
			end
		end
	end

	return false
end
