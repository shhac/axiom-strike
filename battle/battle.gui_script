	hero_head   = vmath.vector4(1.0, 0.85, 0.7, 1),
	hero_hair   = vmath.vector4(0.25, 0.2, 0.6, 1),
	eye_white   = vmath.vector4(1, 1, 1, 1),
	eye_dark    = vmath.vector4(0.15, 0.15, 0.4, 1),

	enemy_body  = vmath.vector4(0.2, 0.8, 0.45, 1),
	enemy_dark  = vmath.vector4(0.12, 0.5, 0.25, 1),
	enemy_dead  = vmath.vector4(0.2, 0.2, 0.25, 0.3),
	enemy_eye   = vmath.vector4(1, 1, 0.92, 1),
	enemy_pupil = vmath.vector4(0.1, 0.1, 0.15, 1),
	enemy_mouth = vmath.vector4(0.06, 0.3, 0.12, 1),

	tile_num    = vmath.vector4(0.2, 0.48, 0.9, 1),
	tile_op     = vmath.vector4(0.92, 0.58, 0.15, 1),
	tile_text   = vmath.vector4(1, 1, 1, 1),
	tile_used   = vmath.vector4(0.12, 0.12, 0.18, 0.35),
	tile_used_t = vmath.vector4(0.3, 0.3, 0.35, 0.35),

	badge_red   = vmath.vector4(1.0, 0.35, 0.25, 1),
	badge_gold  = vmath.vector4(1.0, 0.85, 0.15, 1),

	btn_green   = vmath.vector4(0.15, 0.65, 0.3, 1),
	btn_red     = vmath.vector4(0.8, 0.2, 0.15, 1),

	banner_atk  = vmath.vector4(0.12, 0.22, 0.5, 0.92),
	banner_def  = vmath.vector4(0.5, 0.1, 0.1, 0.92),
	text_atk    = vmath.vector4(0.5, 0.8, 1.0, 1),
