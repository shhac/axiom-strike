-- ============================================================
-- Juice / animation helpers
-- ============================================================

local safe_delete = gui_util.safe_delete

local function bob(node, base_y, amplitude, duration)
	gui.cancel_animation(node, "position.y")
	gui.set_position(node, vmath.vector3(gui.get_position(node).x, base_y, 0))
	gui.animate(node, "position.y", base_y + amplitude, gui.EASING_INOUTSINE, duration, 0, nil, gui.PLAYBACK_LOOP_PINGPONG)
end

local function pop(node, scale_to, duration)
	scale_to = scale_to or 1.15
	duration = duration or 0.15
	gui.cancel_animation(node, gui.PROP_SCALE)
	gui.animate(node, gui.PROP_SCALE, vmath.vector3(scale_to, scale_to, 1), gui.EASING_OUTQUAD, 0.04, 0, function()
		gui.animate(node, gui.PROP_SCALE, vmath.vector3(1, 1, 1), gui.EASING_OUTBACK, duration)
	end)
end

local function pop_text(node)
	gui.cancel_animation(node, gui.PROP_SCALE)
	local s = gui.get_scale(node)
	local big = vmath.vector3(s.x * 1.3, s.y * 1.3, 1)
	gui.set_scale(node, big)
	gui.animate(node, gui.PROP_SCALE, s, gui.EASING_OUTBACK, 0.25)
end

local function flash_white(node, original_color)
	gui.set_color(node, vmath.vector4(1, 1, 1, 1))
	gui.animate(node, gui.PROP_COLOR, original_color, gui.EASING_OUTQUAD, 0.2, 0.05)
end

local function shake(node)
	local pos = gui.get_position(node)
	gui.animate(node, "position.x", pos.x + 6, gui.EASING_OUTELASTIC, 0.35, 0, function()
		gui.set_position(node, pos)
	end)
end

local function slide_in(node, from_x, target_x, delay)
	local pos = gui.get_position(node)
	gui.set_position(node, vmath.vector3(from_x, pos.y, 0))
	gui.set_alpha(node, 0)
	gui.animate(node, "position.x", target_x, gui.EASING_OUTBACK, 0.4, delay or 0)
	gui.animate(node, "color.w", 1, gui.EASING_OUTQUAD, 0.2, delay or 0)
end

-- wiggle removed: GUI rotation.z causes scaling artifacts in Defold

-- ============================================================
-- Hint system
-- ============================================================

local hint_path = nil
local hint_path_step = 0

local function find_best_hint()
	if current_target <= 0 then return nil, nil end

	-- Compute path if not cached or if tiles changed
	if not hint_path then
		hint_path = hint_module.compute_path(current_target, number_tile_values, operator_tile_values, tile_used, equation_tokens, expecting_number)
		hint_path_step = 1
	end

	if hint_path and hint_path_step <= #hint_path then
		local step = hint_path[hint_path_step]
		return step.type, step.index
	end

	return nil, nil
end

local function show_hint()
	if hint_shown or fill_blank_mode then return end

	local hint_type, hint_index = find_best_hint()

	if hint_type == "num" and number_tile_nodes[hint_index] then
		-- Swap to "focused" sprite to highlight
		gui.play_flipbook(number_tile_nodes[hint_index].box, hash("btn_blue"))
		gui.set_color(number_tile_nodes[hint_index].box, C.white)
		-- Gentle pulse on scale
		gui.animate(number_tile_nodes[hint_index].box, gui.PROP_SCALE, vmath.vector3(1.1, 1.1, 1), gui.EASING_INOUTSINE, 0.5, 0, nil, gui.PLAYBACK_LOOP_PINGPONG)
		hint_shown = true
	elseif hint_type == "op" and operator_tile_nodes[hint_index] then
		gui.play_flipbook(operator_tile_nodes[hint_index].box, hash("btn_blue"))
		gui.set_color(operator_tile_nodes[hint_index].box, vmath.vector4(1.0, 0.9, 0.5, 1))
		gui.animate(operator_tile_nodes[hint_index].box, gui.PROP_SCALE, vmath.vector3(1.1, 1.1, 1), gui.EASING_INOUTSINE, 0.5, 0, nil, gui.PLAYBACK_LOOP_PINGPONG)
		hint_shown = true
	end
end

local function clear_hints()
	if hint_shown then
		for i, nd in ipairs(number_tile_nodes) do
			gui.cancel_animation(nd.box, gui.PROP_SCALE)
			gui.play_flipbook(nd.box, hash("btn_brown"))
			gui.set_scale(nd.box, vmath.vector3(1, 1, 1))
			if tile_used["num_" .. i] then
				gui.set_color(nd.box, vmath.vector4(0.3, 0.3, 0.35, 0.4))
			else
				gui.set_color(nd.box, NUM_TINT)
			end
		end
		for i, nd in ipairs(operator_tile_nodes) do
			gui.cancel_animation(nd.box, gui.PROP_SCALE)
			gui.play_flipbook(nd.box, hash("btn_brown"))
			gui.set_scale(nd.box, vmath.vector3(1, 1, 1))
			if tile_used["op_" .. i] then
				gui.set_color(nd.box, vmath.vector4(0.3, 0.3, 0.35, 0.4))
			else
				gui.set_color(nd.box, OP_TINT)
			end
		end
	end
	hint_shown = false
	idle_timer = 0
	-- Invalidate cached path so it recomputes on next hint
	hint_path = nil
	hint_path_step = 0
end

local function show_equation_feedback(result, target, mode, wrong_attempts)
	if eq_feedback_node then
		safe_delete(eq_feedback_node)
		eq_feedback_node = nil
	end

	local msg
	wrong_attempts = wrong_attempts or 0

	if wrong_attempts >= 3 then
		msg = "Try the hint! Look for the glowing tile"
	elseif wrong_attempts >= 2 then
		msg = "= " .. result .. "  (need " .. target .. ") - try using the hint!"
	elseif mode == "attack" then
		msg = "= " .. result .. "  (weakness is " .. target .. ")"
	else
		msg = "= " .. result .. "  (needed " .. target .. ")"
	end

	eq_feedback_node = gui.new_text_node(vmath.vector3(400, 185, 0), msg)
	gui.set_font(eq_feedback_node, "game_font")
	gui.set_scale(eq_feedback_node, vmath.vector3(0.7, 0.7, 1))
	gui.set_color(eq_feedback_node, wrong_attempts >= 2 and vmath.vector4(1, 0.5, 0.3, 1) or vmath.vector4(1, 0.7, 0.4, 1))
	gui.set_alpha(eq_feedback_node, 0)
	gui.animate(eq_feedback_node, "color.w", 1, gui.EASING_OUTQUAD, 0.3)

	-- After 2+ wrong attempts, auto-trigger hint
	if wrong_attempts >= 2 then
		idle_timer = HINT_DELAY
	end

	timer.delay(2.5, false, function()
		if eq_feedback_node then
			gui.animate(eq_feedback_node, "color.w", 0, gui.EASING_OUTQUAD, 0.5, 0, function()
				if eq_feedback_node then
					safe_delete(eq_feedback_node)
					eq_feedback_node = nil
				end
			end)
		end
	end)
end

-- ============================================================
-- Fill-in-the-blank UI
-- ============================================================

local function destroy_fill_blank()
	for _, n in ipairs(fill_blank_nodes) do
		safe_delete(n)
	end
	fill_blank_nodes = {}
	fill_blank_options = {}
	if fill_blank_display_node then safe_delete(fill_blank_display_node); fill_blank_display_node = nil end
	fill_blank_mode = false
end

local function destroy_tile_nodes()
	for _, node in ipairs(number_tile_nodes) do safe_delete(node.box); safe_delete(node.text) end
	for _, node in ipairs(operator_tile_nodes) do safe_delete(node.box); safe_delete(node.text) end
	number_tile_nodes = {}
	operator_tile_nodes = {}
end

local function show_fill_blank_ui(display, options, blank_type)
	destroy_fill_blank()
	destroy_tile_nodes()
	fill_blank_mode = true

	-- Hide normal equation UI
	gui.set_text(gui.get_node("equation_text"), "")
	gui.set_text(gui.get_node("equation_result"), "")

	-- Show the equation with blank prominently
	fill_blank_display_node = gui.new_text_node(vmath.vector3(400, 148, 0), display)
	gui.set_font(fill_blank_display_node, "game_font")
	gui.set_scale(fill_blank_display_node, vmath.vector3(1.5, 1.5, 1))
	gui.set_color(fill_blank_display_node, vmath.vector4(1, 1, 0.95, 1))

	-- Option buttons
	local start_x = 140
	local gap = 140
	for i, opt in ipairs(options) do
		local x = start_x + (i - 1) * gap
		local box = gui.new_box_node(vmath.vector3(x, 55, 0), vmath.vector3(110, 55, 0))
		gui.set_texture(box, "ui")
		if blank_type == "operator" then
			gui.play_flipbook(box, hash("btn_orange"))
		else
			gui.play_flipbook(box, hash("btn_blue"))
		end
		gui.set_size_mode(box, gui.SIZE_MODE_MANUAL)
		gui.set_size(box, vmath.vector3(110, 55, 0))
		gui.set_color(box, C.white)

		local txt = gui.new_text_node(vmath.vector3(x, 55, 0), tostring(opt))
		gui.set_font(txt, "game_font")
		gui.set_scale(txt, vmath.vector3(1.4, 1.4, 1))
		gui.set_color(txt, vmath.vector4(1, 1, 1, 1))

		-- Pop-in
		gui.set_scale(box, vmath.vector3(0, 0, 1))
		gui.animate(box, gui.PROP_SCALE, vmath.vector3(1, 1, 1), gui.EASING_OUTBACK, 0.3, i * 0.08)
		gui.set_alpha(txt, 0)
		gui.animate(txt, "color.w", 1, gui.EASING_OUTQUAD, 0.2, i * 0.08 + 0.1)

		fill_blank_nodes[#fill_blank_nodes + 1] = box
		fill_blank_nodes[#fill_blank_nodes + 1] = txt
		fill_blank_options[i] = {box = box, text = txt, value = opt, index = i}
	end
end

