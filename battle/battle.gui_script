-- ============================================================
-- Scene (hero character)
-- ============================================================

local function create_scene()
	for _, n in ipairs(scene_nodes) do safe_delete(n) end
	scene_nodes = {}

	-- Hero character (pixel art style with colored boxes)
	local body = gui.new_box_node(vmath.vector3(HERO_X, HERO_Y, 0), vmath.vector3(70, 90, 0))
	gui.set_color(body, C.hero_body)
	scene_nodes[#scene_nodes + 1] = body

	local head = gui.new_box_node(vmath.vector3(HERO_X, HERO_Y + 60, 0), vmath.vector3(52, 52, 0))
	gui.set_color(head, C.hero_head)
	scene_nodes[#scene_nodes + 1] = head

	local hair = gui.new_box_node(vmath.vector3(HERO_X, HERO_Y + 84, 0), vmath.vector3(56, 18, 0))
	gui.set_color(hair, C.hero_hair)
	scene_nodes[#scene_nodes + 1] = hair

	-- Eyes
	local el = gui.new_box_node(vmath.vector3(HERO_X - 11, HERO_Y + 63, 0), vmath.vector3(11, 13, 0))
	gui.set_color(el, C.eye_white)
	scene_nodes[#scene_nodes + 1] = el
	local pl = gui.new_box_node(vmath.vector3(HERO_X - 9, HERO_Y + 61, 0), vmath.vector3(6, 7, 0))
	gui.set_color(pl, C.eye_dark)
	scene_nodes[#scene_nodes + 1] = pl
	local er = gui.new_box_node(vmath.vector3(HERO_X + 11, HERO_Y + 63, 0), vmath.vector3(11, 13, 0))
	gui.set_color(er, C.eye_white)
	scene_nodes[#scene_nodes + 1] = er
	local pr = gui.new_box_node(vmath.vector3(HERO_X + 13, HERO_Y + 61, 0), vmath.vector3(6, 7, 0))
	gui.set_color(pr, C.eye_dark)
	scene_nodes[#scene_nodes + 1] = pr

	-- Mouth
	local mouth = gui.new_box_node(vmath.vector3(HERO_X, HERO_Y + 48, 0), vmath.vector3(14, 4, 0))
	gui.set_color(mouth, vmath.vector4(0.75, 0.4, 0.35, 1))
	scene_nodes[#scene_nodes + 1] = mouth

	-- Idle bob on body parts
	for _, n in ipairs(scene_nodes) do
		bob(n, gui.get_position(n).y, 4, 1.8)
	end
end

