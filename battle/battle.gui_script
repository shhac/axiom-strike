-- Dynamic nodes
local number_tile_nodes = {}
local operator_tile_nodes = {}
local number_tile_values = {}
local operator_tile_values = {}
local tile_used = {}
local enemy_nodes = {}
local scene_nodes = {}

-- Equation state
local equation_tokens = {}
local expecting_number = true

-- UI state
local input_enabled = false
local battle_over = false
local between_waves = false

-- Banner/HUD nodes
local banner_bg, banner_text, target_bg, target_text, target_label, wave_text
local enemy_hp_bg, enemy_hp_fill, enemy_hp_text

local SCRIPT_URL = "/battle_controller#script"

-- Layout — compact bottom, big characters
local TILE_W = 68
local TILE_H = 50
local TILE_GAP = 6
local NUM_START_X = 110
local NUM_Y = 55
local OP_START_X = 680
local OP_Y = 55
local ENEMY_START_X = 750
local ENEMY_GAP = 130
local ENEMY_Y = 380
local HERO_X = 220
local HERO_Y = 380

-- Colors
local C = {
