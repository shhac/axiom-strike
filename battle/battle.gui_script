-- ============================================================
-- Juice / animation helpers
-- ============================================================

local function bob(node, base_y, amplitude, duration)
	gui.cancel_animation(node, "position.y")
	gui.set_position(node, vmath.vector3(gui.get_position(node).x, base_y, 0))
	gui.animate(node, "position.y", base_y + amplitude, gui.EASING_INOUTSINE, duration, 0, nil, gui.PLAYBACK_LOOP_PINGPONG)
end

local function pop(node, scale_to, duration)
	scale_to = scale_to or 1.15
	duration = duration or 0.15
	gui.cancel_animation(node, gui.PROP_SCALE)
	gui.animate(node, gui.PROP_SCALE, vmath.vector3(scale_to, scale_to, 1), gui.EASING_OUTQUAD, 0.04, 0, function()
		gui.animate(node, gui.PROP_SCALE, vmath.vector3(1, 1, 1), gui.EASING_OUTBACK, duration)
	end)
end

local function pop_text(node)
	gui.cancel_animation(node, gui.PROP_SCALE)
	local s = gui.get_scale(node)
	local big = vmath.vector3(s.x * 1.3, s.y * 1.3, 1)
	gui.set_scale(node, big)
	gui.animate(node, gui.PROP_SCALE, s, gui.EASING_OUTBACK, 0.25)
end

local function flash_white(node, original_color)
	gui.set_color(node, vmath.vector4(1, 1, 1, 1))
	gui.animate(node, gui.PROP_COLOR, original_color, gui.EASING_OUTQUAD, 0.2, 0.05)
end

local function shake(node)
	local pos = gui.get_position(node)
	gui.animate(node, "position.x", pos.x + 6, gui.EASING_OUTELASTIC, 0.35, 0, function()
		gui.set_position(node, pos)
	end)
end

local function slide_in(node, from_x, target_x, delay)
	local pos = gui.get_position(node)
	gui.set_position(node, vmath.vector3(from_x, pos.y, 0))
	gui.set_alpha(node, 0)
	gui.animate(node, "position.x", target_x, gui.EASING_OUTBACK, 0.4, delay or 0)
	gui.animate(node, "color.w", 1, gui.EASING_OUTQUAD, 0.2, delay or 0)
end

local function wiggle(node, degrees, duration)
	degrees = degrees or 2.5
	duration = duration or 1.2
	gui.animate(node, "rotation.z", degrees, gui.EASING_INOUTSINE, duration, math.random() * 0.5, nil, gui.PLAYBACK_LOOP_PINGPONG)
end

-- ============================================================
-- Scene (hero character)
-- ============================================================

local function create_scene()
	for _, n in ipairs(scene_nodes) do gui.delete_node(n) end
	scene_nodes = {}

	-- Hero body (bigger!)
	local body = gui.new_box_node(vmath.vector3(HERO_X, HERO_Y, 0), vmath.vector3(75, 95, 0))
	gui.set_color(body, C.hero_body)
	scene_nodes[#scene_nodes + 1] = body

	local head = gui.new_box_node(vmath.vector3(HERO_X, HERO_Y + 65, 0), vmath.vector3(55, 55, 0))
	gui.set_color(head, C.hero_head)
	scene_nodes[#scene_nodes + 1] = head

	local hair = gui.new_box_node(vmath.vector3(HERO_X, HERO_Y + 90, 0), vmath.vector3(60, 20, 0))
	gui.set_color(hair, C.hero_hair)
	scene_nodes[#scene_nodes + 1] = hair

	-- Eyes
	local el = gui.new_box_node(vmath.vector3(HERO_X - 12, HERO_Y + 68, 0), vmath.vector3(12, 14, 0))
	gui.set_color(el, C.eye_white)
	scene_nodes[#scene_nodes + 1] = el
	local pl = gui.new_box_node(vmath.vector3(HERO_X - 10, HERO_Y + 66, 0), vmath.vector3(7, 8, 0))
	gui.set_color(pl, C.eye_dark)
	scene_nodes[#scene_nodes + 1] = pl

	local er = gui.new_box_node(vmath.vector3(HERO_X + 12, HERO_Y + 68, 0), vmath.vector3(12, 14, 0))
	gui.set_color(er, C.eye_white)
	scene_nodes[#scene_nodes + 1] = er
	local pr = gui.new_box_node(vmath.vector3(HERO_X + 14, HERO_Y + 66, 0), vmath.vector3(7, 8, 0))
	gui.set_color(pr, C.eye_dark)
	scene_nodes[#scene_nodes + 1] = pr

	-- Smile
	local mouth = gui.new_box_node(vmath.vector3(HERO_X, HERO_Y + 52, 0), vmath.vector3(16, 4, 0))
	gui.set_color(mouth, vmath.vector4(0.75, 0.4, 0.35, 1))
	scene_nodes[#scene_nodes + 1] = mouth

	-- Idle bob on body parts
	for _, n in ipairs(scene_nodes) do
		bob(n, gui.get_position(n).y, 4, 1.8)
	end
end

-- ============================================================
-- HUD (banner + enemy HP)
-- ============================================================

local function create_hud()
